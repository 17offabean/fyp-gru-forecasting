    "# ─── Plot 3: FFT Power Spectrum of Log Returns ───────────────────────────────\n",
    "# The power spectrum reveals any dominant periodicities (cycles) in the return series.\n",
    "# For an efficient market, we expect NO strong peaks — power should decay as ~1/f.\n",
    "\n",
    "# 1. Extract clean log returns as a 1-D numpy array (drop the leading NaN)\n",
    "log_ret = df_clean['log_ret'].dropna().values\n",
    "N = len(log_ret)\n",
    "\n",
    "# Sampling rate: 1 observation per trading day; 252 trading days/year\n",
    "# d=252 means frequencies will be in cycles per YEAR (more interpretable)\n",
    "dt = 252.0\n",
    "\n",
    "# 2. Compute one-sided FFT and corresponding frequency axis\n",
    "fft_vals = np.fft.rfft(log_ret)       # Complex-valued FFT coefficients\n",
    "freqs = np.fft.rfftfreq(N, d=dt)      # Frequency bins (cycles/day when d=252 → cycles/year)\n",
    "\n",
    "# 3. Power spectrum: |FFT|^2 (energy at each frequency)\n",
    "power = np.abs(fft_vals) ** 2\n",
    "\n",
    "# 4. Plot\n",
    "plt.figure(figsize=(12, 5))\n",
    "plt.plot(freqs, power, linewidth=1)\n",
    "plt.xlabel(\"Frequency (cycles per day)\")\n",
    "plt.ylabel(\"Power (|FFT|^2)\")\n",
    "plt.title(f\"{symbol} - Power Spectrum of Log Returns\")\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
